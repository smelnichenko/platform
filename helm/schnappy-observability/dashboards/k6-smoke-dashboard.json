{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Check Pass Rate",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 1,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "green", "value": 1 }
            ]
          },
          "unit": "percentunit"
        }
      },
      "targets": [{
        "expr": "k6_checks{check=~\".+\"}",
        "legendFormat": "{{check}}"
      }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "Total Checks (Last Run)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "targets": [{
        "expr": "k6_checks_total",
        "legendFormat": "total checks"
      }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "HTTP Requests by Group",
      "type": "stat",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      },
      "targets": [{
        "expr": "k6_http_reqs_total",
        "legendFormat": "{{group}}"
      }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "HTTP Request Duration (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 2000 }
            ]
          }
        }
      },
      "targets": [{
        "expr": "histogram_quantile(0.95, rate(k6_http_req_duration_seconds_bucket[5m])) * 1000",
        "legendFormat": "p95"
      }, {
        "expr": "histogram_quantile(0.50, rate(k6_http_req_duration_seconds_bucket[5m])) * 1000",
        "legendFormat": "p50"
      }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "HTTP Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.01 }
            ]
          }
        }
      },
      "targets": [{
        "expr": "k6_http_req_failed_rate",
        "legendFormat": "error rate"
      }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "Check Results History",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      },
      "targets": [{
        "expr": "k6_checks{check=~\".+\"}",
        "legendFormat": "{{check}}"
      }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    }
  ],
  "schemaVersion": 39,
  "tags": ["k6", "smoke-test"],
  "templating": { "list": [] },
  "time": { "from": "now-7d", "to": "now" },
  "timepicker": {},
  "timezone": "utc",
  "title": "k6 Smoke Tests",
  "uid": "k6-smoke-tests"
}
