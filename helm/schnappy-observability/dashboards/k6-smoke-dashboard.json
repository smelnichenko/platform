{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Check Pass Rate",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 1,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "green", "value": 1 }
            ]
          },
          "unit": "percentunit"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{
        "expr": "last_over_time(k6_checks_rate[1d])",
        "legendFormat": "pass rate"
      }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "Total Checks (Last Run)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{
        "expr": "last_over_time(k6_iterations_total[1d])",
        "legendFormat": "iterations"
      }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "HTTP Requests by Group",
      "type": "stat",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{
        "expr": "last_over_time(k6_http_reqs_total[1d])",
        "legendFormat": "{{group}}"
      }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "HTTP Request Duration (ms)",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 2000 }
            ]
          }
        }
      },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [{
        "expr": "histogram_avg(last_over_time(k6_http_req_duration_seconds[1d])) * 1000",
        "legendFormat": "{{group}}"
      }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "HTTP Error Rate",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.01 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{
        "expr": "last_over_time(k6_http_req_failed_rate[1d])",
        "legendFormat": "error rate"
      }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "Check Results History",
      "type": "state-timeline",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 14 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "1": { "text": "PASS", "color": "green" } } },
            { "type": "range", "options": { "from": 0, "to": 0.99, "result": { "text": "FAIL", "color": "red" } } }
          ]
        }
      },
      "targets": [{
        "expr": "k6_checks_rate or last_over_time(k6_checks_rate[6h])",
        "legendFormat": "smoke test",
        "intervalFactor": 1
      }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "Request Duration History",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [{
        "expr": "histogram_avg(k6_http_req_duration_seconds) * 1000 or histogram_avg(last_over_time(k6_http_req_duration_seconds[6h])) * 1000",
        "legendFormat": "{{group}}"
      }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    }
  ],
  "schemaVersion": 39,
  "tags": ["k6", "smoke-test"],
  "templating": { "list": [] },
  "time": { "from": "now-7d", "to": "now" },
  "timepicker": {},
  "timezone": "utc",
  "title": "k6 Smoke Tests",
  "uid": "k6-smoke-tests"
}
