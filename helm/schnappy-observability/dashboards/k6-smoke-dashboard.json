{
  "annotations": { "list": [] },
  "description": "k6 smoke test results — runs after every Argo CD sync (PostSync) and daily at 6 AM UTC",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Check Pass Rate",
      "description": "Percentage of all k6 checks that passed in the last run. 100% = all endpoints healthy.",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 1,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "green", "value": 1 }
            ]
          },
          "unit": "percentunit"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{
        "expr": "avg(last_over_time(k6_checks_rate[1d]))",
        "legendFormat": "pass rate"
      }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "Total Checks (Last Run)",
      "description": "Number of k6 iterations completed. Should always be 1 (single smoke test run).",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{
        "expr": "last_over_time(k6_iterations_total[1d])",
        "legendFormat": "iterations"
      }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "HTTP Requests by Group",
      "description": "Number of HTTP requests per endpoint group.\n\nactuator = /api/actuator/health (Spring Boot)\napproval-mode = /api/auth/approval-mode\nbuild-info = /api/build-info (git hash + build time)\nfrontend = / (React SPA via nginx)\nhealth = /api/health (app health)\nkeycloak = auth.pmon.dev OIDC discovery\npermissions = /api/permissions/required",
      "type": "stat",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{
        "expr": "last_over_time(k6_http_reqs_total[1d])",
        "legendFormat": "{{group}}"
      }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "HTTP Request Duration (ms)",
      "description": "Average response time per endpoint group. Yellow > 500ms, red > 2s.\n\nactuator is typically slow (~1s) on first call due to Spring Boot health check (DB, disk).",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 2000 }
            ]
          }
        }
      },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [{
        "expr": "histogram_avg(last_over_time(k6_http_req_duration_seconds[1d])) * 1000",
        "legendFormat": "{{group}}"
      }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "HTTP Error Rate",
      "description": "Percentage of HTTP requests that returned non-2xx status. Should be 0%.",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.01 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{
        "expr": "avg(last_over_time(k6_http_req_failed_rate[1d]))",
        "legendFormat": "error rate"
      }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "Check Results History",
      "description": "Pass/fail timeline over time. Green = all checks passed, red = one or more failed. Runs daily at 6 AM + after every Argo CD sync.",
      "type": "state-timeline",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 14 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "1": { "text": "PASS", "color": "green" } } },
            { "type": "range", "options": { "from": 0, "to": 0.99, "result": { "text": "FAIL", "color": "red" } } }
          ]
        }
      },
      "targets": [{
        "expr": "avg(k6_checks_rate) or avg(last_over_time(k6_checks_rate[6h]))",
        "legendFormat": "smoke test"
      }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "Request Duration History",
      "description": "Response time trend per endpoint group over time. Each dot is one smoke test run. Useful for spotting performance regressions.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "pointSize": 5, "drawStyle": "points", "showPoints": "always" }
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [{
        "expr": "histogram_avg(k6_http_req_duration_seconds) * 1000 or histogram_avg(last_over_time(k6_http_req_duration_seconds[6h])) * 1000",
        "legendFormat": "{{group}}"
      }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    }
  ],
  "schemaVersion": 39,
  "tags": ["k6", "smoke-test"],
  "templating": { "list": [] },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "utc",
  "title": "k6 Smoke Tests",
  "uid": "k6-smoke-tests"
}
