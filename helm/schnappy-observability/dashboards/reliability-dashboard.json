{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "tags": ["reliability", "sre"],
  "title": "Reliability",
  "uid": "reliability",
  "schemaVersion": 39,
  "timezone": "",
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": { "list": [] },
  "panels": [
    {
      "type": "row",
      "id": 1,
      "title": "Vault",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "type": "stat",
      "id": 2,
      "title": "Vault endpoints reachable",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "sum(probe_success{job=\"blackbox-vault\"})" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "green", "value": 3 }
            ]
          },
          "max": 3, "min": 0
        }
      },
      "options": { "graphMode": "none", "textMode": "value_and_name" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 }
    },
    {
      "type": "timeseries",
      "id": 3,
      "title": "Vault probe HTTP status by instance",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "probe_http_status_code{job=\"blackbox-vault\"}", "legendFormat": "{{instance}}" }
      ],
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 1 }
    },
    {
      "type": "row",
      "id": 10,
      "title": "External Secrets",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false
    },
    {
      "type": "stat",
      "id": 11,
      "title": "ClusterSecretStore Ready",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "external_secrets_cluster_secret_store_condition{condition=\"Ready\", status=\"true\"}", "legendFormat": "{{name}}" }
      ],
      "fieldConfig": { "defaults": { "mappings": [{ "type": "value", "options": { "0": { "text": "NOT READY", "color": "red" }, "1": { "text": "READY", "color": "green" } } }] } },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 10 }
    },
    {
      "type": "timeseries",
      "id": 12,
      "title": "ExternalSecret sync errors (rate 10m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "sum by (namespace) (rate(externalsecret_sync_calls_error[10m]))", "legendFormat": "{{namespace}}" }
      ],
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 10 }
    },
    {
      "type": "row",
      "id": 20,
      "title": "ArgoCD",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "collapsed": false
    },
    {
      "type": "stat",
      "id": 21,
      "title": "Apps by health",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "count by (health_status) (argocd_app_info)", "legendFormat": "{{health_status}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [ { "color": "green", "value": null } ]
          },
          "mappings": []
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Degraded" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] },
          { "matcher": { "id": "byName", "options": "Missing" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } } ] }
        ]
      },
      "options": { "textMode": "value_and_name", "colorMode": "value" },
      "gridPos": { "h": 6, "w": 10, "x": 0, "y": 19 }
    },
    {
      "type": "table",
      "id": 22,
      "title": "Degraded apps",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "argocd_app_info{health_status=\"Degraded\"}", "format": "table", "instant": true }
      ],
      "transformations": [
        { "id": "organize", "options": { "indexByName": { "name": 0, "project": 1, "sync_status": 2 }, "excludeByName": { "Time": true, "Value": true, "__name__": true, "autopilot": true, "job": true, "instance": true, "container": true, "endpoint": true, "namespace": true, "pod": true, "service": true } } }
      ],
      "gridPos": { "h": 6, "w": 14, "x": 10, "y": 19 }
    },
    {
      "type": "row",
      "id": 30,
      "title": "Velero",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "collapsed": false
    },
    {
      "type": "stat",
      "id": 31,
      "title": "Hours since last successful daily backup",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "(time() - max(velero_backup_last_successful_timestamp{schedule=\"velero-schnappy-daily\"})) / 3600" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 26 }, { "color": "red", "value": 30 } ] },
          "unit": "h"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 26 }
    },
    {
      "type": "timeseries",
      "id": 32,
      "title": "Backup success rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "rate(velero_backup_success_total[5m])", "legendFormat": "success" },
        { "refId": "B", "expr": "rate(velero_backup_failure_total[5m])", "legendFormat": "failure" }
      ],
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 26 }
    },
    {
      "type": "row",
      "id": 40,
      "title": "Public URLs",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 34 },
      "collapsed": false
    },
    {
      "type": "stat",
      "id": 41,
      "title": "Probe status",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "probe_success{job=\"blackbox-public\"}", "legendFormat": "{{instance}}", "instant": true }
      ],
      "fieldConfig": { "defaults": { "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }] } },
      "options": { "textMode": "value_and_name" },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 35 }
    },
    {
      "type": "stat",
      "id": 42,
      "title": "SSL days left",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "(probe_ssl_earliest_cert_expiry{job=\"blackbox-public\"} - time()) / 86400", "legendFormat": "{{instance}}", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 14 }, { "color": "green", "value": 30 } ] },
          "unit": "d"
        }
      },
      "options": { "textMode": "value_and_name" },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 35 }
    },
    {
      "type": "timeseries",
      "id": 43,
      "title": "Public URL probe duration",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "probe_duration_seconds{job=\"blackbox-public\"}", "legendFormat": "{{instance}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 41 }
    }
  ]
}
