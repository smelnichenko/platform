<?xml version="1.0"?>
<!--
  No "default" user — ClickHouse's bootstrap user is removed so the
  cluster never accepts the well-known "default" username. The
  application user is `schnappy`, password from CLICKHOUSE_PASSWORD
  (sha256 hex injected at startup as CLICKHOUSE_PASSWORD_SHA256).
  Fluent-bit, Grafana, and the init Job all use this user.
-->
<clickhouse>
  <profiles>
    <default>
      <max_memory_usage>1500000000</max_memory_usage>
      <log_queries>1</log_queries>
    </default>
  </profiles>
  <users replace="replace">
    <schnappy>
      <password_sha256_hex from_env="CLICKHOUSE_PASSWORD_SHA256"/>
      <networks>
        <ip>::/0</ip>
      </networks>
      <profile>default</profile>
      <quota>default</quota>
      <access_management>0</access_management>
    </schnappy>
  </users>
  <quotas>
    <default>
      <interval>
        <duration>3600</duration>
        <queries>0</queries>
        <errors>0</errors>
        <result_rows>0</result_rows>
        <read_rows>0</read_rows>
        <execution_time>0</execution_time>
      </interval>
    </default>
  </quotas>
</clickhouse>
